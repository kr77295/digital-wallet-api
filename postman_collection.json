{
  "info": {
    "name": "Digital Wallet API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\",\n  \"defaultCurrency\": \"USD\"\n}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\"\n}"
        }
      }
    },
    {
      "name": "Get Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "Get Balance",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/wallet/balance"
      }
    },
    {
      "name": "Add Funds",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/wallet/add-funds",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 500,\n  \"currency\": \"USD\"\n}"
        }
      }
    },
    {
      "name": "Withdraw",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/wallet/withdraw",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 50,\n  \"currency\": \"USD\"\n}"
        }
      }
    },
    {
      "name": "Transfer",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/wallet/transfer",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 25,\n  \"currency\": \"USD\",\n  \"recipientEmail\": \"friend@example.com\"\n}"
        }
      }
    },
    {
      "name": "Transaction History",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/transactions?page=1&limit=20"
      }
    }
  ]
}
